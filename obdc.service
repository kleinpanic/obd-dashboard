[Unit]
Description=OBD Commander Car Computer
After=network.target

[Service]
Type=simple
WorkingDirectory=/home/broklein/codeWS/Python/obd-dashboard
Environment=PATH=/home/broklein/codeWS/Python/obd-dashboard/venv/bin
ExecStart=/home/broklein/codeWS/Python/obd-dashboard/venv/bin/python server.py --host 0.0.0.0 --port 9000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
