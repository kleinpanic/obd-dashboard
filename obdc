#!/usr/bin/env python3
"""
OBD Commander CLI - Full control over car computer system

Commands:
  obdc status              # Connection and vehicle info
  obdc scan                # List all sensors with values
  obdc get <sensor>        # Get single sensor value
  obdc live                # Stream live data (JSON lines)
  obdc vin                 # Get VIN
  obdc dtc                 # Get diagnostic trouble codes
  obdc capabilities        # Show what can be controlled
  
  obdc server start        # Start web server
  obdc server stop         # Stop web server  
  obdc server status       # Server status
  obdc server restart      # Restart server
  
  obdc db query <sql>      # Query SQLite database
  obdc db export           # Export all data as JSON
  obdc db clear            # Clear database
  obdc db stats            # Database statistics
  
  obdc log tail            # Tail recent sensor logs
  obdc log follow          # Follow live updates
"""

import sys
import json
import subprocess
import sqlite3
import time
import os
import signal
from pathlib import Path
from datetime import datetime, timedelta

try:
    import obd
    OBD_AVAILABLE = True
except ImportError:
    OBD_AVAILABLE = False

# Paths
DATA_DIR = Path.home() / ".local/share/obdc"
DATA_DIR.mkdir(parents=True, exist_ok=True)
DB_PATH = DATA_DIR / "obdc.db"
PID_FILE = DATA_DIR / "server.pid"
LOG_FILE = DATA_DIR / "obdc.log"
SERVER_SCRIPT = Path(__file__).parent / "server.py"

def get_connection():
    """Get OBD connection"""
    if not OBD_AVAILABLE:
        return None
    ports = obd.scan_serial()
    if not ports:
        return None
    try:
        conn = obd.OBD(ports[0], protocol="6", fast=False)
        if conn.is_connected():
            return conn
    except:
        pass
    return None

def cmd_status(args):
    """Show connection status"""
    result = {"connected": False, "vehicle": None}
    
    conn = get_connection()
    if conn:
        result["connected"] = True
        result["protocol"] = conn.protocol_name()
        result["sensors_supported"] = len(conn.supported_commands)
        
        try:
            vin = conn.query(obd.commands.VIN)
            if not vin.is_null():
                result["vehicle"] = {"vin": str(vin.value)}
        except:
            pass
        conn.close()
    
    # Server status
    if PID_FILE.exists():
        pid = int(PID_FILE.read_text().strip())
        try:
            os.kill(pid, 0)  # Check if process exists
            result["server"] = {"running": True, "pid": pid}
        except OSError:
            result["server"] = {"running": False, "stale_pid": pid}
    else:
        result["server"] = {"running": False}
    
    print(json.dumps(result, indent=2))

def cmd_scan(args):
    """Scan all sensors"""
    conn = get_connection()
    if not conn:
        print(json.dumps({"error": "Not connected"}))
        return
    
    sensors = {}
    for cmd in conn.supported_commands:
        try:
            resp = conn.query(cmd)
            if not resp.is_null():
                val = resp.value
                sensors[cmd.name] = {
                    "pid": cmd.pid,
                    "value": float(val.magnitude) if hasattr(val, 'magnitude') and isinstance(val.magnitude, (int, float)) else str(val),
                    "unit": str(val.units) if hasattr(val, 'units') else "",
                }
        except:
            pass
    
    conn.close()
    print(json.dumps({"sensors": sensors, "count": len(sensors)}, indent=2))

def cmd_get(args):
    """Get single sensor"""
    if len(args) < 1:
        print(json.dumps({"error": "Usage: obdc get <sensor_name>"}))
        return
    
    conn = get_connection()
    if not conn:
        print(json.dumps({"error": "Not connected"}))
        return
    
    sensor_name = args[0].upper()
    for cmd in conn.supported_commands:
        if cmd.name == sensor_name:
            resp = conn.query(cmd)
            conn.close()
            if not resp.is_null():
                val = resp.value
                print(json.dumps({
                    "name": cmd.name,
                    "pid": cmd.pid,
                    "value": float(val.magnitude) if hasattr(val, 'magnitude') and isinstance(val.magnitude, (int, float)) else str(val),
                    "unit": str(val.units) if hasattr(val, 'units') else "",
                }, indent=2))
                return
            else:
                print(json.dumps({"error": "No data"}))
                return
    
    conn.close()
    print(json.dumps({"error": f"Sensor {sensor_name} not found"}))

def cmd_live(args):
    """Stream live data"""
    interval = float(args[0]) if args else 1.0
    
    conn = get_connection()
    if not conn:
        print(json.dumps({"error": "Not connected"}))
        return
    
    key_sensors = ['RPM', 'SPEED', 'COOLANT_TEMP', 'INTAKE_TEMP', 'THROTTLE_POS', 
                    'FUEL_LEVEL', 'ENGINE_LOAD', 'MAF', 'TIMING_ADVANCE']
    
    try:
        while True:
            data = {"timestamp": datetime.utcnow().isoformat() + "Z", "sensors": {}}
            for cmd in conn.supported_commands:
                if cmd.name in key_sensors:
                    try:
                        resp = conn.query(cmd)
                        if not resp.is_null():
                            val = resp.value
                            data["sensors"][cmd.name] = {
                                "value": float(val.magnitude) if hasattr(val, 'magnitude') else str(val),
                                "unit": str(val.units) if hasattr(val, 'units') else "",
                            }
                    except:
                        pass
            print(json.dumps(data), flush=True)
            time.sleep(interval)
    except KeyboardInterrupt:
        pass
    finally:
        conn.close()

def cmd_vin(args):
    """Get VIN"""
    conn = get_connection()
    if not conn:
        print(json.dumps({"error": "Not connected"}))
        return
    
    try:
        vin = conn.query(obd.commands.VIN)
        conn.close()
        if not vin.is_null():
            print(json.dumps({"vin": str(vin.value)}, indent=2))
        else:
            print(json.dumps({"error": "VIN not available"}))
    except Exception as e:
        conn.close()
        print(json.dumps({"error": str(e)}))

def cmd_dtc(args):
    """Get DTCs"""
    conn = get_connection()
    if not conn:
        print(json.dumps({"error": "Not connected"}))
        return
    
    dtcs = []
    try:
        resp = conn.query(obd.commands.GET_DTC)
        if not resp.is_null():
            dtcs = [(code, desc) for code, desc in resp.value]
    except:
        pass
    conn.close()
    print(json.dumps({"dtc": dtcs, "count": len(dtcs)}, indent=2))

def cmd_capabilities(args):
    """Show capabilities"""
    conn = get_connection()
    if not conn:
        print(json.dumps({"error": "Not connected"}))
        return
    
    supported = [cmd.name for cmd in conn.supported_commands]
    read_only = []
    writable = []
    
    for name in supported:
        if any(x in name for x in ['CONTROL', 'TEST', 'CLEAR']):
            writable.append(name)
        else:
            read_only.append(name)
    
    conn.close()
    print(json.dumps({
        "protocol": conn.protocol_name(),
        "total_supported": len(supported),
        "read_only": read_only,
        "potentially_writable": writable,
        "warning": "OBD-II is primarily read-only. Write commands require specific protocols."
    }, indent=2))

# Server commands
def cmd_server(args):
    """Server management"""
    if not args:
        print(json.dumps({"error": "Usage: obdc server [start|stop|status|restart]"}))
        return
    
    subcmd = args[0]
    
    if subcmd == "start":
        port = int(args[1]) if len(args) > 1 else 8000
        venv_python = Path(__file__).parent / "venv/bin/python"
        python = str(venv_python) if venv_python.exists() else sys.executable
        
        proc = subprocess.Popen(
            [python, str(SERVER_SCRIPT), "--port", str(port)],
            stdout=open(LOG_FILE, 'a'),
            stderr=subprocess.STDOUT,
            start_new_session=True
        )
        PID_FILE.write_text(str(proc.pid))
        print(json.dumps({"status": "started", "pid": proc.pid, "port": port, "url": f"http://localhost:{port}"}))
    
    elif subcmd == "stop":
        if not PID_FILE.exists():
            print(json.dumps({"error": "Server not running"}))
            return
        
        pid = int(PID_FILE.read_text().strip())
        try:
            os.kill(pid, signal.SIGTERM)
            PID_FILE.unlink()
            print(json.dumps({"status": "stopped", "pid": pid}))
        except OSError:
            PID_FILE.unlink()
            print(json.dumps({"error": "Process already dead"}))
    
    elif subcmd == "status":
        if not PID_FILE.exists():
            print(json.dumps({"running": False}))
            return
        
        pid = int(PID_FILE.read_text().strip())
        try:
            os.kill(pid, 0)
            print(json.dumps({"running": True, "pid": pid}))
        except OSError:
            print(json.dumps({"running": False, "stale_pid": pid}))
    
    elif subcmd == "restart":
        cmd_server(["stop"])
        time.sleep(1)
        cmd_server(["start"] + args[1:])

# Database commands
def cmd_db(args):
    """Database management"""
    if not args:
        print(json.dumps({"error": "Usage: obdc db [query|export|clear|stats]"}))
        return
    
    subcmd = args[0]
    
    if subcmd == "query":
        if len(args) < 2:
            print(json.dumps({"error": "Usage: obdc db query <sql>"}))
            return
        sql = " ".join(args[1:])
        conn = sqlite3.connect(DB_PATH)
        try:
            c = conn.cursor()
            c.execute(sql)
            if sql.upper().startswith("SELECT"):
                rows = c.fetchall()
                print(json.dumps({"rows": rows, "count": len(rows)}, indent=2))
            else:
                conn.commit()
                print(json.dumps({"affected": c.rowcount}))
        except Exception as e:
            print(json.dumps({"error": str(e)}))
        finally:
            conn.close()
    
    elif subcmd == "export":
        conn = sqlite3.connect(DB_PATH)
        c = conn.cursor()
        c.execute("SELECT timestamp, sensor, value, unit FROM sensor_data ORDER BY timestamp")
        rows = c.fetchall()
        conn.close()
        
        data = [{
            "timestamp": r[0],
            "datetime": datetime.utcfromtimestamp(r[0]).isoformat(),
            "sensor": r[1],
            "value": r[2],
            "unit": r[3]
        } for r in rows]
        
        print(json.dumps(data, indent=2))
    
    elif subcmd == "clear":
        conn = sqlite3.connect(DB_PATH)
        c = conn.cursor()
        c.execute("DELETE FROM sensor_data")
        conn.commit()
        count = c.rowcount
        conn.close()
        print(json.dumps({"cleared": count}))
    
    elif subcmd == "stats":
        conn = sqlite3.connect(DB_PATH)
        c = conn.cursor()
        c.execute("SELECT COUNT(*) FROM sensor_data")
        total = c.fetchone()[0]
        c.execute("SELECT COUNT(DISTINCT sensor) FROM sensor_data")
        sensors = c.fetchone()[0]
        c.execute("SELECT MIN(timestamp), MAX(timestamp) FROM sensor_data")
        time_range = c.fetchone()
        conn.close()
        
        print(json.dumps({
            "total_readings": total,
            "unique_sensors": sensors,
            "time_range": {
                "start": datetime.utcfromtimestamp(time_range[0]).isoformat() if time_range[0] else None,
                "end": datetime.utcfromtimestamp(time_range[1]).isoformat() if time_range[1] else None
            }
        }, indent=2))

# Log commands
def cmd_log(args):
    """Log management"""
    if not args:
        print(json.dumps({"error": "Usage: obdc log [tail|follow]"}))
        return
    
    subcmd = args[0]
    
    if subcmd == "tail":
        lines = int(args[1]) if len(args) > 1 else 50
        if LOG_FILE.exists():
            result = subprocess.run(["tail", "-n", str(lines), str(LOG_FILE)], capture_output=True, text=True)
            print(result.stdout)
        else:
            print(json.dumps({"error": "No log file"}))
    
    elif subcmd == "follow":
        if LOG_FILE.exists():
            subprocess.run(["tail", "-f", str(LOG_FILE)])
        else:
            print(json.dumps({"error": "No log file"}))

def print_help():
    print(__doc__)

def main():
    args = sys.argv[1:]
    
    if not args:
        print_help()
        return
    
    cmd = args[0]
    rest = args[1:]
    
    commands = {
        "status": cmd_status,
        "scan": cmd_scan,
        "get": cmd_get,
        "live": cmd_live,
        "vin": cmd_vin,
        "dtc": cmd_dtc,
        "capabilities": cmd_capabilities,
        "server": cmd_server,
        "db": cmd_db,
        "log": cmd_log,
        "help": lambda _: print_help(),
    }
    
    if cmd in commands:
        commands[cmd](rest)
    else:
        print(f"Unknown command: {cmd}")
        print_help()

if __name__ == "__main__":
    main()
